# Webull OpenAPI
WEBULL_APP_KEY=
WEBULL_APP_SECRET=
WEBULL_REGION_ID=us
# production: api.webull.com | test/UAT: us-openapi-alb.uat.webullbroker.com
WEBULL_ENDPOINT=api.webull.com
# Optional: set once known to skip auto-discovery via get_account_list
WEBULL_ACCOUNT_ID=

# Optional: narrow the order-history pull (default: Webull's own "last 7 days")
WEBULL_ORDER_START_DATE=
WEBULL_ORDER_END_DATE=
WEBULL_ORDER_PAGE_SIZE=100
# Shared across EVERY Webull trade-endpoint call in one cycle (order/history pages AND
# order/detail fee fetches) -- Webull documents order-query endpoints at 2 requests /
# 2 seconds. Two independently-paced loops at "1/sec each" can still combine to exceed
# that; one shared limiter is what actually enforces it.
WEBULL_TRADE_API_MIN_INTERVAL_SECONDS=1.0
# How many not-yet-actualized orders' real fees to fetch per sync cycle. Trades appear
# instantly either way with the zero-API-call estimate (see fee_rates.py); this just
# controls how fast the backlog converges to real fees without bursting the rate limit.
WEBULL_FEE_BACKFILL_BATCH_SIZE=10

# Sync worker scheduling (only used by `python sync.py`, not `--once`)
SYNC_INTERVAL_MINUTES=15
# If true, the scheduled loop skips cycles outside market hours (Mon-Fri,
# [SYNC_MARKET_START_HOUR, SYNC_MARKET_END_HOUR) America/New_York) and on US market
# holidays (see market_calendar.py) -- with a small taper of extra syncs right after
# close, see below. Manual refresh (POST /sync/trigger) ignores this entirely and
# always runs on demand. --once also always runs regardless of this flag.
SYNC_MARKET_HOURS_ONLY=false
SYNC_MARKET_START_HOUR=9
SYNC_MARKET_END_HOUR=17
# How long after close to keep allowing a few more syncs (catches fills/fees still
# settling), and how many syncs that taper window gets before going fully quiet
# overnight.
SYNC_AFTER_CLOSE_TAPER_HOURS=1
SYNC_AFTER_CLOSE_MAX_SYNCS=2

# Manual-refresh HTTP endpoint (see sync_trigger_server.py). Required for the
# frontend's "Sync Now" button to work -- generate a long random value and set the
# SAME value as a Vercel env var (never VITE_-prefixed; server-side only).
SYNC_TRIGGER_SECRET=
# How long the manual-refresh endpoint enforces between triggers, so the button can't
# be spammed into a Webull 429.
SYNC_TRIGGER_DEBOUNCE_SECONDS=60
# Port the endpoint listens on -- Fly sets $PORT automatically; only override for
# local testing.
PORT=8080

# Supabase
SUPABASE_URL=
# Must be the SECRET key (sb_secret_...), NOT the publishable key (sb_publishable_...).
# The publishable key can't bypass RLS, so writes will silently vanish from any
# .select() call even though inserts appear to succeed.
SUPABASE_SERVICE_ROLE_KEY=
# Your Supabase Auth user's UUID (Studio -> Authentication -> Users) -- every row the
# worker writes is stamped with this, since the service-role key operates outside any
# user session and RLS can't infer it.
WEBULL_USER_ID=
# Optional: the migrated Webull account's row id (accounts.id in Supabase Studio --
# NOT WEBULL_ACCOUNT_ID above, which is Webull's own brokerage account id used only for
# API calls). Every trade this worker writes gets stamped with it. Safe to leave unset
# -- trades.account_id is nullable, so the worker keeps syncing exactly as before if
# this isn't configured yet.
JOURNAL_ACCOUNT_ID=
