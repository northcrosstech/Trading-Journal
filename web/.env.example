# Supabase project (client-side -- must be the PUBLISHABLE/anon key, never the
# secret key the worker uses. RLS is what actually restricts each user to their own
# rows; this key alone grants no special access.)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Manual-refresh proxy (api/_lib/triggerSync.ts, used by web/api/trigger-sync.ts and
# the matching vite dev middleware) -- never VITE_-prefixed, these must stay
# server-side only.
# The worker's public https URL (its Fly app URL, e.g. https://<app>.fly.dev).
WORKER_SYNC_URL=
# Must match the worker's SYNC_TRIGGER_SECRET exactly (worker/.env.example).
SYNC_TRIGGER_SECRET=
